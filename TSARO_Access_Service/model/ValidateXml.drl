package oracle.communications.inventory.rules;

import oracle.communications.inventory.api.framework.logging.Log;
import oracle.communications.inventory.extensibility.extension.util.ExtensionPointContext;
import accessServiceValidateXML.ValidateBiAttachment;
 
 
global Log log;
 
rule "Validate VALIDATECAPTUREINTERACTION"
	salience 0
	when
    	context : ExtensionPointContext()      
    then 
    ValidateBiAttachment validateAccRequest= new ValidateBiAttachment();
    validateAccRequest.validateRequest(context, log);
    end