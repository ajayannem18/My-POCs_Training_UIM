<act:match>
<act:diff>
<act:path>/root/after/accessDevice</act:path>
</act:diff>
<act:action>TA_ACCESS_PE_CREATE</act:action>
<act:action>TA_SWITCH_ACCESS_FIBER_CREATE</act:action>
<act:action>TA_OLT_ACCESS_GPON_CREATE</act:action>
<act:anchor>..</act:anchor>
</act:match>
 
	
<act:generator>
<act:action>TA_ACCESS_PE_CREATE</act:action>
<act:condition>(boolean(count(/root/service[state='PENDING']) > 0) and (/root/after/accessDevice/mediaType = 'Fiber') or (/root/after/accessDevice/mediaType = 'GPON') or (/root/after/accessDevice/mediaType = 'Microwave'))
</act:condition>
<act:subject>/root/service</act:subject>
<act:target>/root/service</act:target>
<act:binding>
<act:parameter>mediaType</act:parameter>
<act:path>/root/after/accessDevice/mediaType</act:path>
</act:binding>
<act:binding>
<act:parameter>peDeviceName</act:parameter>
<act:path>/root/after/accessDevice/PeDevice/Assignment[@State='PENDING_ASSIGN']/name</act:path>
</act:binding>
 
	</act:generator>

