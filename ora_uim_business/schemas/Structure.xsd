<xs:schema 
    targetNamespace="http://xmlns.oracle.com/communications/inventory/structure" 
    xmlns:invstruc="http://xmlns.oracle.com/communications/inventory/structure" 
    xmlns:invprop="http://xmlns.oracle.com/communications/inventory/property" 
    xmlns="http://www.w3.org/2001/XMLSchema" 
    xmlns:xsd="http://www.w3.org/2001/XMLSchema" 
    xmlns:xs="http://www.w3.org/2001/XMLSchema" 
    elementFormDefault="qualified">
  <!--  =================== Imports Start ==================== -->
  <!-- Local Imports -->
  <xs:import namespace="http://xmlns.oracle.com/communications/inventory/property" schemaLocation="Property.xsd"/>
  <!-- ==== Entity Value Types ==== -->
    <xs:complexType name="StructuredType">
        <xs:annotation>
            <xs:documentation>StructuredType holds a structured set of items.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="name" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        Holds name of Structured Type
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="property" type="invprop:PropertyType" nillable="true" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>
                        Item holds the items
                        of a Structured Type.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="child" type="invstruc:StructuredType" nillable="true" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>
                        Holds child structure. 
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
</xs:schema>

