<?xml version='1.0' encoding='windows-1252'?>
<jsp:root xmlns:jsp="http://java.sun.com/JSP/Page" version="2.1" xmlns:af="http://xmlns.oracle.com/adf/faces/rich" xmlns:f="http://java.sun.com/jsf/core" xmlns:c="http://java.sun.com/jsp/jstl/core">
    <c:set var="inventoryUIBundle" value="#{adfBundle['oracle.communications.inventory.ui.common.bundle.InventoryUIBundle']}"/>
    <af:showDetailHeader text="#{inventoryUIBundle.ASSOCIATED_LDS}" disclosed="true" id="sdh3">
        <af:panelCollection id="LDList" styleClass="AFStretchWidth">
			<f:facet name="toolbar">
				<af:toolbar id="t3">
					<af:commandToolbarButton text="#{inventoryUIBundle.EXPORT}" immediate="true" shortDesc="#{inventoryUIBundle.EXPORT_ALL_ROWS}" 
											 icon="/images/exporttoexcel_ena.png" disabledIcon="/images/exporttoexcel_dis.png" partialTriggers="resultsTableId"
                                             id="ctb1">
                        <af:exportCollectionActionListener type="#{pageFlowScope.LogicalDeviceListBean.exportType}" exportedId="resultsTableId"
                                    filename="#{inventoryUIBundle.ASSOCIATED_LDS} - #{pageFlowScope.networkDisplayInfo}.xls" title="Export" exportedRows="all"/>
                    </af:commandToolbarButton>
				</af:toolbar>
			</f:facet>
            <f:facet name="statusbar">
                <af:toolbar id="bdat1">
                    <af:outputText value="#{inventoryUIBundle.ROW_COUNT} #{(bindings.searchResultsIterator.dataControl.dataProvider.collectionModel.rowCount lt 0) ? 0 : bindings.searchResultsIterator.dataControl.dataProvider.collectionModel.rowCount}"
                                   styleClass="invSearchOutputLabel" binding="#{backingBeanScope.totalResultsLabel}" partialTriggers="resultsTableId"
                                   id="bdaot1"/>
                </af:toolbar>
            </f:facet>
            <af:table id="resultsTableId" value="#{bindings.searchResultsIterator.dataControl.dataProvider.collectionModel}" var="row"
                      emptyText="#{bindings.searchResults.viewable ? inventoryUIBundle.TABLE_EMPTY_TEXT_NO_ROWS_YET : inventoryUIBundle.TABLE_EMPTY_TEXT_ACCESS_DENIED}"
                      fetchSize="#{(bindings.searchResultsIterator.dataControl.dataProvider.collectionModel.rowCount &lt; 25) ? bindings.searchResultsIterator.dataControl.dataProvider.collectionModel.rowCount : 25}"
                      filterModel="#{pageFlowScope.LogicalDeviceQueryBean.filterModel}" selectionListener="#{pageFlowScope.LogicalDeviceListBean.selectAction}"
                      queryListener="#{InventoryHelperBean.processQuery}" filterVisible="false" varStatus="vs" autoHeightRows="#{pageFlowScope.LogicalDeviceListBean.portletHeight}"
                      contentDelivery="immediate" sortListener="#{bindings.searchResultsIterator.dataControl.dataProvider.processSort}"
                      rowSelection="#{pageFlowScope.LogicalDeviceListBean.rowSelection}" styleClass="AFStretchWidth"
                      selectedRowKeys="#{bindings.searchResultsIterator.dataControl.dataProvider.collectionModel.selectedRow}" columnStretching="last"
                      binding="#{pageFlowScope.LogicalDeviceListBean.resultsTable}" summary="#{inventoryUIBundle.LOGICAL_DEVICE_LIST}">
                <af:column headerText="#{inventoryUIBundle.ID}" id="c3" sortable="true" filterable="true" sortProperty="id">
                    <af:link id="c200" action="ldSummary" actionListener="#{pageFlowScope.LogicalDeviceListBean.navigate}">
                        <af:outputText value="#{row.id}" id="ot17"/>
                        <af:setActionListener from="#{row.oid}" to="#{pageFlowScope.objectId}"/>
                    </af:link>
                </af:column>
                <af:column headerText="#{inventoryUIBundle.NAME}" id="c1" sortable="true" filterable="true" sortProperty="name">
                    <af:outputText value="#{row.name}" id="ot18"/>
                </af:column>
                <af:column headerText="#{inventoryUIBundle.SPECIFICATION}" id="c7" sortable="true" filterable="true" sortProperty="specification.name">
                    <af:link action="SpecificationSummary" id="clSpec1" actionListener="#{pageFlowScope.LogicalDeviceListBean.navigateToSpecSummary}">
                        <af:outputText value="#{pageFlowScope.LogicalDeviceListBean.specDisplayNameForCollectionModelLists}" id="ot14"/>
                        <af:setActionListener from="#{row.specification.oid}" to="#{specObjectId}"/>
                    </af:link>
                </af:column>
                <af:column headerText="#{inventoryUIBundle.INVENTORY_STATUS}" id="c21" sortable="true" filterable="true" sortProperty="adminState">
                    <af:outputText value="#{pageFlowScope.LogicalDeviceListBean.inventoryStatus}" id="ot71"/>
                    <af:outputText value="#{pageFlowScope.LogicalDeviceListBean.inventoryStatusBIDueDate}" id="pendingBIDueDate2"/>
                    <af:switcher id="swisld618" defaultFacet="false" facetName="#{pageFlowScope.LogicalDeviceListBean.popupMode}">
                        <f:facet name="false">
                            <af:commandImageLink action="#{pageFlowScope.LogicalDeviceListBean.getInventoryStatusSummaryAction}" id="bidld3"
                                                 actionListener="#{pageFlowScope.LogicalDeviceListBean.registerRecentItem}" text="#{pageFlowScope.LogicalDeviceListBean.inventoryStatusBILabel}"
                                                 shortDesc="#{pageFlowScope.LogicalDeviceListBean.installingBIShortDesc}" disabled="#{pageFlowScope.LogicalDeviceListBean.installingBIDisabled}">
                                <af:setActionListener from="#{pageFlowScope.LogicalDeviceListBean.inventoryStatusReferencedBI.oid}" to="#{objectId}"/>
                            </af:commandImageLink>
                        </f:facet>
                        <f:facet name="true">
                            <af:outputText value="#{pageFlowScope.LogicalDeviceListBean.inventoryStatusBILabel}" id="swftisld618"/>
                        </f:facet>
                    </af:switcher>
                </af:column>
                <af:column headerText="#{inventoryUIBundle.NETWORK_NODE_ID}" id="c2">
                    <af:outputText value="#{pageFlowScope.LogicalDeviceListBean.networkNodeID}" id="ot11"/>
                </af:column>
				<af:column headerText="#{inventoryUIBundle.MENU_TOPOLOGY}" id="ct2">
                    <af:link text="#{inventoryUIBundle.VIEW_TOPOLOGY}" id="to11" rendered="#{(pageFlowScope.LogicalDeviceListBean.renderTopologyMS)}" targetFrame="_blank" destination="#{pageFlowScope.LogicalDeviceListBean.topologyURL}"   disabled="#{pageFlowScope.LogicalDeviceListBean.disableTopologyButton}"/>
<af:link text="#{inventoryUIBundle.VIEW_TOPOLOGY}" id="to12" action="searchInTopologyADF" rendered="#{!(pageFlowScope.LogicalDeviceListBean.renderTopologyMS)}" actionListener="#{pageFlowScope.LogicalDeviceListBean.navigateToTopology}"/>
                </af:column>
            </af:table>
        </af:panelCollection>
    </af:showDetailHeader>
</jsp:root>
